{
  "name": "archkit-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "globals": "^15",
    "prettier": "^3.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "vitest": "^3.2"
  }
}
