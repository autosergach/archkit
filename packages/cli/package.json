{
  "name": "archkit",
  "version": "0.1.0",
  "description": "Clean Architecture project generator for TypeScript",
  "keywords": [
    "scaffold",
    "generator",
    "cli",
    "clean-architecture",
    "typescript",
    "template",
    "ddd",
    "hexagonal"
  ],
  "homepage": "https://github.com/autosergach/archkit#readme",
  "bugs": {
    "url": "https://github.com/autosergach/archkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/autosergach/archkit.git"
  },
  "license": "MIT",
  "author": "Alex Rogov <autosergach@gmail.com> (https://github.com/autosergach)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "archkit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm -w build && pnpm -w test && pnpm -w test:e2e"
  },
  "dependencies": {
    "archkit-core": "workspace:*",
    "cac": "^6.7.14",
    "@inquirer/prompts": "^7"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
